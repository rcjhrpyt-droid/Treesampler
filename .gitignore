# R package ignores
^.*\.Rproj$
^\.Rproj\.user$
^\.Rhistory$
^\.RData$
^\.Ruserdata$

# Build artifacts
^src/.*\.o$
^src/.*\.so$
^src/.*\.dll$

# Documentation (auto-generated by roxygen2)
# Keep man/ if you commit .Rd files

# Test artifacts
^tests/testthat/_snaps/
^tests/.rds$

# OS files
.DS_Store
Thumbs.db

# Development scripts (not part of package)
test_verify.R
run_app.R
.Rproj.user
