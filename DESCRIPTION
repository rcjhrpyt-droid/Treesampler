Package: treesampler
Title: Tree-Structured Sampling from Tabular Data
Version: 0.1.0
Authors@R: person("wenzhe", "Huang", email = "51280155097@stu.ecnu.edu.cn", role = c("aut", "cre"))
Description: Provides tools to build hierarchical tree structures from nominal
    variables in tabular data and perform stratified sampling at each tree level.
    Designed for generating representative subsets to test code on, reducing the
    cost of trial-and-error during data analysis. Includes an interactive Shiny
    app for visual tree confirmation and sampling configuration.
Imports:
    data.tree,
    dplyr,
    shiny,
    DT,
    collapsibleTree,
    readxl,
    readr
Suggests:
    ggplot2
Depends:
    R (>= 3.5.0)
